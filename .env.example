# ===========================================
# Signalmash Connect - Environment Variables
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/signalmash_connect?schema=public"

# Redis (for sessions, queues, caching)
REDIS_URL="redis://localhost:6379"

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
SESSION_SECRET=your-session-secret-change-in-production
ENCRYPTION_KEY=your-32-character-encryption-key!

# Signalmash API
SIGNALMASH_API_URL=https://api.signalmash.com
SIGNALMASH_API_KEY=your-signalmash-api-key
SIGNALMASH_ACCOUNT_SID=your-signalmash-account-sid

# GoHighLevel (GHL)
GHL_APP_CLIENT_ID=your-ghl-client-id
GHL_APP_CLIENT_SECRET=your-ghl-client-secret
GHL_APP_SSO_KEY=your-ghl-sso-key
GHL_API_DOMAIN=https://services.leadconnectorhq.com
GHL_WEBHOOK_SECRET=your-ghl-webhook-secret

# Shopify (Future)
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret

# HubSpot (Future)
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret

# Salesforce (Future)
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret

# Zoho (Future)
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret

# Email (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@yourdomain.com

# Sentry (Error tracking - optional)
SENTRY_DSN=
