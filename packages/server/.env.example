# ===========================================
# Server Configuration
# ===========================================

NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/signalmash_connect?schema=public

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# Security (Generate with: openssl rand -hex 32)
# ===========================================
JWT_SECRET=your-32-character-minimum-jwt-secret-key-here
JWT_REFRESH_SECRET=your-32-character-minimum-refresh-secret-key
SESSION_SECRET=your-32-character-minimum-session-secret-key
ENCRYPTION_KEY=exactly32characterslongkeyheres  # Must be exactly 32 chars

# ===========================================
# Signalmash API
# Note: API key can also be configured via Admin Portal
# ===========================================
SIGNALMASH_API_URL=https://api.signalmash.com
SIGNALMASH_API_KEY=your-signalmash-api-key
SIGNALMASH_ACCOUNT_SID=your-signalmash-account-sid

# ===========================================
# GoHighLevel (GHL) Integration
# ===========================================
GHL_APP_CLIENT_ID=your-ghl-app-client-id
GHL_APP_CLIENT_SECRET=your-ghl-app-client-secret
GHL_APP_SSO_KEY=your-ghl-app-sso-key
GHL_API_DOMAIN=https://services.leadconnectorhq.com
GHL_WEBHOOK_SECRET=optional-webhook-secret

# ===========================================
# Future Platform Integrations (Optional)
# ===========================================
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=

# ===========================================
# Email (Optional)
# ===========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# FROM_EMAIL=noreply@example.com

# ===========================================
# Monitoring (Optional)
# ===========================================
# SENTRY_DSN=your-sentry-dsn
