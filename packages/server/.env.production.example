# ===========================================
# Production Configuration Template
# ===========================================
# Copy this file to .env and fill in your values

NODE_ENV=production
PORT=3001
API_URL=https://api.yourdomain.com
WEB_URL=https://app.yourdomain.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://signalmash:YOUR_SECURE_PASSWORD@localhost:5432/signalmash?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Security Keys (MUST be unique, random 32+ character strings)
# Generate with: openssl rand -hex 32
JWT_SECRET=GENERATE_A_SECURE_32_CHAR_STRING_HERE
JWT_REFRESH_SECRET=GENERATE_ANOTHER_SECURE_32_CHAR_STRING
SESSION_SECRET=GENERATE_ANOTHER_SECURE_32_CHAR_STRING
ENCRYPTION_KEY=EXACTLY_32_CHARACTERS_HERE_1234

# Signalmash (configure via Admin Portal or here)
SIGNALMASH_API_URL=https://api.signalmash.com
SIGNALMASH_API_KEY=your-signalmash-api-key
SIGNALMASH_ACCOUNT_SID=your-signalmash-account-sid

# GHL App Credentials
GHL_APP_CLIENT_ID=69cdf3964b99ed2e21cc1e7c-mnxo2len
GHL_APP_CLIENT_SECRET=4cb78e4f-e33a-4416-973c-971955a783de
GHL_APP_SSO_KEY=placeholder
GHL_API_DOMAIN=https://services.leadconnectorhq.com
